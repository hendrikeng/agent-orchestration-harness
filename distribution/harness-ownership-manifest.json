{
  "schemaVersion": 1,
  "description": "Root-level distribution manifest for syncing the template payload into downstream repositories.",
  "sourceRoot": "template",
  "targetRoot": ".",
  "ownershipMode": "template-sync",
  "downstreamManifestPath": "docs/ops/automation/harness-manifest.json",
  "managedGlobs": [
    "**/*"
  ],
  "bootstrapOnlyGlobs": [
    "PLACEHOLDERS.md",
    "package.scripts.fragment.json"
  ],
  "excludeGlobs": [
    ".gitignore",
    "docs/ops/automation/harness-manifest.json"
  ]
}
