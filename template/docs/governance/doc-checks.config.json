  "activePlans": {
    "directory": "docs/exec-plans/active",
    "excludeFiles": [
      "README.md",
      ".gitkeep"
    ],
    "requireMetadataSection": true,
    "requiredMetadataFields": [
      "Plan-ID",
      "Status",
      "Priority",
      "Owner",
      "Acceptance-Criteria",
      "Delivery-Class",
      "Dependencies",
      "Spec-Targets",
      "Implementation-Targets",
      "Risk-Tier",
      "Validation-Lanes",
      "Security-Approval",
      "Done-Evidence"
    ]
  },
  "completedPlans": {
    "directory": "docs/exec-plans/completed",
    "excludeFiles": [
      "README.md",
      ".gitkeep"
    ],
    "requiredPatterns": [
      {
        "regex": "^##\\s+Closure\\b",
        "message": "Completed plans must include a Closure section."
      },
      {
        "regex": "^##\\s+Validation Evidence\\b",
        "message": "Completed plans must include validation evidence."
      },
      {
        "regex": "-\\s+Status:\\s*completed\\b",
        "message": "Completed plans must set Status: completed."
      }
    ]
  },
  "currentStateDateCoupling": {
    "readmePath": "README.md",
    "currentStatePath": "docs/product-specs/CURRENT-STATE.md",
    "fieldName": "Current State Date"
  },
  "jsonSchemaValidation": [
    {
      "dataPath": "docs/governance/policy-manifest.json",
      "schemaPath": "docs/governance/policy-manifest.schema.json"
    },
    {
      "dataPath": "docs/governance/project-gates.json",
