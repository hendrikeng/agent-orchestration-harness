{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-project-blueprint/policy-manifest.schema.json",
  "title": "Policy Manifest",
  "type": "object",
  "required": [
    "version",
    "mandatorySafetyRules",
    "executionModel",
    "validationPolicy",
    "executionQuality",
    "runControl",
    "memoryPosture",
    "docContract",
    "gitSafetyContract"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "mandatorySafetyRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "requiredInRuntimeContext"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 8
          },
          "requiredInRuntimeContext": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "executionModel": {
      "type": "object",
      "required": [
        "mode",
        "queue",
        "sourceOfTruth"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 8
        },
        "queue": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 4
          }
        },
        "sourceOfTruth": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 4
          }
        }
      },
      "additionalProperties": false
    },
    "validationPolicy": {
      "type": "object",
      "required": [
        "fastIteration",
        "fullGate",
        "repoHealth",
        "notes"
      ],
      "properties": {
        "fastIteration": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 4
          }
        },
        "fullGate": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 4
          }
        },
        "repoHealth": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 4
          }
        },
        "notes": {
          "type": "string",
          "minLength": 8
        }
      },
      "additionalProperties": false
    },
    "executionQuality": {
      "type": "object",
      "required": [
        "goalDrivenExecution",
        "simplicityAndScope",
        "assumptionDiscipline"
      ],
      "properties": {
        "goalDrivenExecution": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "simplicityAndScope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "assumptionDiscipline": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        }
      },
      "additionalProperties": false
    },
    "runControl": {
      "type": "object",
      "required": [
        "goalDrivenRunControl",
        "delegationPolicy",
        "runtimeExecutionPolicy",
        "completionAudit"
      ],
      "properties": {
        "goalDrivenRunControl": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "delegationPolicy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "runtimeExecutionPolicy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "completionAudit": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        }
      },
      "additionalProperties": false
    },
    "memoryPosture": {
      "type": "object",
      "required": [
        "whatToDo",
        "improveBeforeRearchitecture",
        "doNotAddYet",
        "escalateWhen",
        "safeRule"
      ],
      "properties": {
        "whatToDo": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "improveBeforeRearchitecture": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "doNotAddYet": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "escalateWhen": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 8
          }
        },
        "safeRule": {
          "type": "string",
          "minLength": 16
        }
      },
      "additionalProperties": false
    },
    "docContract": {
      "type": "object",
      "required": [
        "canonicalEntryPoints",
        "requiresSameChangeUpdateFor"
      ],
      "properties": {
        "canonicalEntryPoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 4
          }
        },
        "requiresSameChangeUpdateFor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 4
          }
        }
      },
      "additionalProperties": false
    },
    "gitSafetyContract": {
      "type": "object",
      "required": [
        "forbiddenWithoutExplicitInstruction",
        "notes"
      ],
      "properties": {
        "forbiddenWithoutExplicitInstruction": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "notes": {
          "type": "string",
          "minLength": 8
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
